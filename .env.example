# Application Settings
APP_NAME="Vehicle Tracking System Backend"
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database Settings
# Replace with your PostgreSQL credentials. 
# Sync database URL (for Alembic and sync connections)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vts_db
# Async database URL (for FastAPI async engine)
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vts_db

# Logging Settings
LOG_LEVEL=INFO
